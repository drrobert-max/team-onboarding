# ─────────────────────────────────────────────────────────────────────────────
# Reformation Training Hub — environment configuration
# Copy to `.env` for local dev, or set these as variables on your host (Railway).
# ─────────────────────────────────────────────────────────────────────────────

# ─── Core ────────────────────────────────────────────────────────────────────
NODE_ENV=production
# Port the server listens on. Railway injects this automatically.
PORT=3000
# Secret used to sign session (JWT) cookies. Use a long random string.
JWT_SECRET=change-me-to-a-long-random-string
# Public URL of the deployed app (used in emails, etc.). Optional.
PUBLIC_BASE_URL=https://your-app.up.railway.app

# ─── Database (MySQL) ────────────────────────────────────────────────────────
# Full connection string. On Railway, add a MySQL plugin and reference its URL.
DATABASE_URL=mysql://user:password@host:3306/reformation_training
# Set to "true" to auto-apply migrations on server start (recommended on deploy).
RUN_MIGRATIONS=true

# ─── LLM (OpenAI-compatible Chat Completions API) ────────────────────────────
# Works with OpenAI or any OpenAI-compatible endpoint / gateway.
LLM_BASE_URL=https://api.openai.com
LLM_API_KEY=sk-...
LLM_MODEL=gpt-4o-mini
# Max output tokens per completion (keep within your model's limit).
LLM_MAX_TOKENS=8192

# ─── Object storage (S3-compatible) ──────────────────────────────────────────
# AWS S3, Cloudflare R2, MinIO, etc. Used for training videos, audio and images.
S3_BUCKET=reformation-training-media
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
# Set only for non-AWS providers (e.g. https://<account>.r2.cloudflarestorage.com)
S3_ENDPOINT=
# Some providers (R2/MinIO) require path-style URLs — set "true" for those.
S3_FORCE_PATH_STYLE=false
# Seconds a presigned URL stays valid.
S3_SIGNED_URL_TTL=3600

# ─── Email (Gmail via nodemailer) ────────────────────────────────────────────
# Used for password resets, welcome emails and owner notifications.
# Create a Google "App Password" (requires 2FA) and paste it below.
GMAIL_USER=selena@reformationchiropractic.com
GMAIL_APP_PASSWORD=
# Where owner notifications are sent (defaults to GMAIL_USER).
OWNER_EMAIL=selena@reformationchiropractic.com

# ─── Scheduled jobs ──────────────────────────────────────────────────────────
# Set "true" to run the weekly Google Drive sync jobs in-process (single
# instance only). Leave unset if you drive /api/scheduled/* from an external
# scheduler instead.
ENABLE_CRON=false

# ─── Optional: extra allowed dev hosts (comma-separated) ─────────────────────
ALLOWED_HOSTS=
